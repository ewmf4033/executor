#!/usr/bin/python3
"""
executorctl — operator CLI for the Executor daemon control socket.

Standalone script: pure Python stdlib. Does NOT import the executor
package and does NOT require /root/executor/.venv to be healthy. The
operator must be able to engage kill even if the venv is broken.

Usage:
    executorctl ping
    executorctl version
    executorctl kill status
    executorctl kill soft  <reason>
    executorctl kill hard  <reason>
    executorctl kill panic <reason>
    executorctl kill resume
    executorctl arm --timeout 6h
    executorctl disarm --reason "session end"
    executorctl heartbeat
    executorctl arm_status

Socket path: $EXECUTOR_CONTROL_SOCKET, default /run/executor/control.sock.

Exit codes:
    0 — ok
    1 — daemon responded with ok=false
    2 — connection / IO failure (daemon not running, permission denied, ...)
    3 — invalid CLI arguments
"""
from __future__ import annotations

import argparse
import errno
import json
import os
import socket
import sys


DEFAULT_SOCKET = "/run/executor/control.sock"
CONNECT_TIMEOUT_SEC = 2.0
READ_TIMEOUT_SEC = 5.0
SOURCE_TAG = "executorctl"
MAX_RESPONSE_BYTES = 1_000_000


def _io_fail(msg: str) -> "Exception":
    print(f"executorctl: {msg}", file=sys.stderr)
    sys.exit(2)


def _connect(path: str) -> socket.socket:
    if not os.path.exists(path):
        _io_fail(f"socket not found at {path} — is the daemon running?")
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(CONNECT_TIMEOUT_SEC)
    try:
        s.connect(path)
    except PermissionError:
        _io_fail(
            f"permission denied on {path} — run as root or check socket ownership"
        )
    except ConnectionRefusedError:
        _io_fail(f"connection refused at {path} — daemon not accepting connections")
    except OSError as exc:
        if exc.errno == errno.EACCES:
            _io_fail(
                f"permission denied on {path} — run as root or check socket ownership"
            )
        _io_fail(f"connect failed: {exc}")
    s.settimeout(READ_TIMEOUT_SEC)
    return s


def _send(path: str, cmd: str, args: dict | None = None) -> dict:
    payload = {"cmd": cmd, "args": args or {}, "source": SOURCE_TAG}
    s = _connect(path)
    try:
        s.sendall((json.dumps(payload) + "\n").encode("utf-8"))
        buf = b""
        while b"\n" not in buf:
            try:
                chunk = s.recv(4096)
            except socket.timeout:
                _io_fail("timeout waiting for response")
            if not chunk:
                break
            buf += chunk
            if len(buf) > MAX_RESPONSE_BYTES:
                _io_fail("response exceeded max size")
        if not buf:
            _io_fail("empty response — daemon closed connection")
        line = buf.split(b"\n", 1)[0]
        try:
            return json.loads(line.decode("utf-8"))
        except (json.JSONDecodeError, UnicodeDecodeError) as exc:
            _io_fail(f"protocol error: {exc}")
    finally:
        try:
            s.close()
        except OSError:
            pass


def _print_snapshot(result: dict) -> None:
    parts = [
        f"mode={result.get('mode', '?')}",
        f"panic={result.get('panic', '?')}",
        f"manual_only={result.get('manual_only', '?')}",
        f"strikes={result.get('strikes', '?')}",
    ]
    reason = result.get("reason") or ""
    if reason:
        parts.append(f"reason={reason!r}")
    if result.get("resume_blocked"):
        parts.append(f"resume_blocked={result['resume_blocked']!r}")
    print(" ".join(parts))


def _handle_err(resp: dict) -> int:
    err = resp.get("error", "unknown error")
    code = resp.get("code", "?")
    print(f"executorctl: error ({code}): {err}", file=sys.stderr)
    return 1


def cmd_ping(args: argparse.Namespace) -> int:
    resp = _send(args.socket, "ping")
    if not resp.get("ok"):
        return _handle_err(resp)
    r = resp["result"]
    print(
        f"pong uptime={r.get('daemon_uptime_sec', '?')}s "
        f"protocol_version={r.get('protocol_version', '?')}"
    )
    return 0


def cmd_version(args: argparse.Namespace) -> int:
    resp = _send(args.socket, "version")
    if not resp.get("ok"):
        return _handle_err(resp)
    r = resp["result"]
    print(
        f"executor_version={r.get('executor_version', 'unknown')} "
        f"protocol_version={r.get('protocol_version', '?')} "
        f"git_sha={r.get('git_sha') or 'unknown'}"
    )
    return 0


def _parse_timeout(raw: str) -> int:
    """Parse a duration string with optional s/m/h suffix into seconds.

    Accepts "300", "5m", "6h". Rejects "1d" (day suffix) per T1 safety —
    the dead-man ceiling caps at 12h; operators who want longer should
    explicitly write "43200" in seconds.
    """
    if not raw:
        raise ValueError("empty timeout")
    unit = raw[-1].lower()
    if unit.isdigit():
        value = int(raw)
        return value
    if unit == "s":
        return int(raw[:-1])
    if unit == "m":
        return int(raw[:-1]) * 60
    if unit == "h":
        return int(raw[:-1]) * 3600
    raise ValueError(f"unsupported timeout unit {unit!r} — use s/m/h or bare seconds")


def _fmt_duration(seconds: int) -> str:
    """Format seconds as compact HhMmSs. Negative -> "-XsY"."""
    sign = "-" if seconds < 0 else ""
    s = abs(int(seconds))
    h, rem = divmod(s, 3600)
    m, sec = divmod(rem, 60)
    parts = []
    if h:
        parts.append(f"{h}h")
    if m:
        parts.append(f"{m}m")
    parts.append(f"{sec}s")
    return sign + "".join(parts)


def cmd_arm(args: argparse.Namespace) -> int:
    try:
        timeout_sec = _parse_timeout(args.timeout)
    except ValueError as exc:
        print(f"executorctl: invalid --timeout: {exc}", file=sys.stderr)
        return 3
    resp = _send(args.socket, "arm", {"timeout_sec": timeout_sec})
    if not resp.get("ok"):
        return _handle_err(resp)
    r = resp["result"]
    print(
        f"armed for {_fmt_duration(timeout_sec)} | "
        f"kill_mode_at_arm={r.get('kill_mode_at_arm', '?')}"
    )
    return 0


def cmd_disarm(args: argparse.Namespace) -> int:
    if not args.reason:
        print("executorctl: --reason is required for disarm", file=sys.stderr)
        return 3
    resp = _send(args.socket, "disarm", {"reason": args.reason})
    if not resp.get("ok"):
        return _handle_err(resp)
    r = resp["result"]
    print(f"disarmed — reason: {r.get('disarmed_reason', args.reason)}")
    return 0


def cmd_heartbeat(args: argparse.Namespace) -> int:
    resp = _send(args.socket, "heartbeat")
    if not resp.get("ok"):
        return _handle_err(resp)
    r = resp["result"]
    if not r.get("armed"):
        print("heartbeat ignored — dead-man is disarmed")
        return 0
    seconds_until_stale = int(r.get("seconds_until_stale", 0))
    print(f"heartbeat ok — {_fmt_duration(seconds_until_stale)} until stale")
    return 0


def cmd_arm_status(args: argparse.Namespace) -> int:
    resp = _send(args.socket, "arm_status")
    if not resp.get("ok"):
        return _handle_err(resp)
    r = resp["result"]
    if not r.get("armed"):
        print("armed=False")
        return 0
    last_hb = int(r.get("last_heartbeat_ts_ns", 0))
    import time as _time
    hb_age_sec = int((_time.time_ns() - last_hb) / 1e9) if last_hb else -1
    until_stale = int(r.get("seconds_until_stale", 0))
    timeout = int(r.get("timeout_sec", 0))
    print(
        f"armed=True timeout={_fmt_duration(timeout)} "
        f"hb_age={_fmt_duration(hb_age_sec)} "
        f"until_stale={_fmt_duration(until_stale)} "
        f"kill_mode_at_arm={r.get('kill_mode_at_arm', '?')}"
    )
    return 0


def cmd_kill(args: argparse.Namespace) -> int:
    sub = args.kill_sub
    if sub == "status":
        resp = _send(args.socket, "kill_status")
    elif sub in ("soft", "hard", "panic"):
        resp = _send(args.socket, "kill", {"sub": sub, "reason": args.reason})
    elif sub == "resume":
        resp = _send(args.socket, "kill", {"sub": "resume"})
    else:
        print(f"executorctl: unknown kill sub: {sub}", file=sys.stderr)
        return 3
    if not resp.get("ok"):
        return _handle_err(resp)
    _print_snapshot(resp["result"])
    return 0


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="executorctl",
        description="Operator CLI for the Executor daemon control socket.",
    )
    parser.add_argument(
        "--socket",
        default=os.environ.get("EXECUTOR_CONTROL_SOCKET", DEFAULT_SOCKET),
        help=(
            "Path to control socket "
            f"(default: $EXECUTOR_CONTROL_SOCKET or {DEFAULT_SOCKET})"
        ),
    )
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("ping", help="diagnostic liveness check")
    sub.add_parser("version", help="report executor + protocol version")
    kill = sub.add_parser("kill", help="engage/resume the kill switch")
    kill_sub = kill.add_subparsers(dest="kill_sub", required=True)
    kill_sub.add_parser("status", help="show current kill state")
    for engage in ("soft", "hard", "panic"):
        p = kill_sub.add_parser(engage, help=f"engage {engage} kill")
        p.add_argument("reason", help="operator-supplied reason (required)")
    kill_sub.add_parser("resume", help="clear kill state")

    # Phase 4.14b — dead-man operator liveness commands.
    arm = sub.add_parser("arm", help="arm the dead-man switch")
    arm.add_argument(
        "--timeout",
        required=True,
        help="heartbeat timeout; accepts seconds or s/m/h suffix (e.g. 6h)",
    )
    disarm = sub.add_parser("disarm", help="disarm the dead-man switch")
    disarm.add_argument("--reason", required=True, help="operator reason")
    sub.add_parser("heartbeat", help="send an explicit dead-man heartbeat")
    sub.add_parser("arm_status", help="show dead-man arm + heartbeat state")
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = _build_parser()
    try:
        args = parser.parse_args(argv)
    except SystemExit as exc:
        # argparse exits with 2 on usage errors. Map to 3 per the CLI
        # contract; keep 0 (help) and any other code as-is.
        code = exc.code if isinstance(exc.code, int) else 1
        if code == 2:
            return 3
        return code
    if args.cmd == "ping":
        return cmd_ping(args)
    if args.cmd == "version":
        return cmd_version(args)
    if args.cmd == "kill":
        return cmd_kill(args)
    if args.cmd == "arm":
        return cmd_arm(args)
    if args.cmd == "disarm":
        return cmd_disarm(args)
    if args.cmd == "heartbeat":
        return cmd_heartbeat(args)
    if args.cmd == "arm_status":
        return cmd_arm_status(args)
    print(f"executorctl: unknown command: {args.cmd}", file=sys.stderr)
    return 3


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
