# Template for /root/executor/.env. Copy to .env, fill real values, then:
#   chown root:root /root/executor/.env && chmod 0400 /root/executor/.env
# .env is gitignored; this file is the documented variable schema only.
# DO NOT commit real values to this file.

# Telegram (currently consumed in paper + live)
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Kalshi (future — required for live mode only; leave unset in paper)
KALSHI_API_KEY_ID=replace_me
KALSHI_PRIVATE_KEY_PATH=/root/kalshi_sports.key

# Optional runtime metadata (deferred PRE-T1; see trading-wiki/ops/secrets.md)
EXECUTOR_GIT_SHA=optional
